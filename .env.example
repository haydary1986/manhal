# توكن البوت من BotFather (مطلوب)
BOT_TOKEN=123456:ABCDEF_your_token_here

# رابط Postgres (اتركه فارغاً لاستخدام التخزين بالذاكرة أثناء التطوير)
DATABASE_URL=

# مفتاح DeepSeek (اتركه فارغاً لتعطيل ميزات الذكاء الاصطناعي)
DEEPSEEK_API_KEY=

# سقف استخدامات الذكاء اليومي لكل مستخدم (0 = بلا حد)
AI_DAILY_LIMIT=5

# فترة استطلاع التنبيهات بالدقائق (الأوراق الجديدة + تذكير المواعيد)؛ 0 = تعطيل
ALERT_INTERVAL_MINUTES=360

# عدد الأيام قبل الموعد النهائي لبدء التذكير الاستباقي
REMINDER_WINDOW_DAYS=7

# يوم إرسال الموجز الأسبوعي (0=الأحد .. 6=السبت)
DIGEST_WEEKDAY=0

# embeddings المحلية (Ollama) للبحث الدلالي #22 ومحادثة PDF #24.
# مع docker-compose يُنزَّل النموذج تلقائياً (خدمة ollama-pull). اتركه فارغاً للتعطيل.
# OLLAMA_URL يُضبَط تلقائياً في compose — لا داعي لتعديله هنا.
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=bge-m3

# بريد التواصل لمجمّع Crossref/OpenAlex المهذّب (اختياري — يُسرّع الطلبات)
CROSSREF_MAILTO=

# بريد Unpaywall (مطلوب لميزة «نسخة مجانية»؛ يرجع لـ CROSSREF_MAILTO إن تُرك فارغاً)
UNPAYWALL_EMAIL=

# معرّفات الأدمن مفصولة بفواصل، مثال: 11111111,22222222
ADMIN_IDS=

# مجلد ملفات الإعدادات القابلة للتعديل
DATA_DIR=data

# عنوان خادم لوحة الأدمن على الويب
WEB_ADDR=:8080

# كلمة مرور أدمن الويب الرئيسي (Basic Auth، اسم المستخدم: admin).
# اتركها فارغة (مع ADMIN_WEB_USERS) لتعطيل لوحة الويب نهائياً.
ADMIN_WEB_TOKEN=

# أدمنون إضافيون للوحة الويب: user:pass مفصولون بفواصل
# مثال: ADMIN_WEB_USERS=ahmed:pass1,sara:pass2
ADMIN_WEB_USERS=
